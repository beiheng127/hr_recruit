server:
  port: 5500

spring:
  application:
    name: hr-recruit
  profiles:
    active: dev

  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/hr_recruit?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password:  # 请填写你的MySQL密码

  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true
    encoding: utf-8

  servlet:
    multipart:
      max-file-size: 20MB
      max-request-size: 30MB

  mail:
    host: smtp.qq.com
    port: 587
    username: your_email@qq.com  # 请填写发件邮箱
    password: your_smtp_authorization_code  # 请填写SMTP授权码
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

  ai:
    openai:
      api-key: sk-your-api-key-here  # 请填写DeepSeek API Key
      base-url: https://api.deepseek.com
      chat:
        options:
          model: deepseek-chat
          temperature: 0.7

# 文件上传配置
app:
  upload:
    path: ${USERPROFILE}/hr-recruit/uploads/

mybatis-plus:
  global-config:
    db-config:
      id-type: auto
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

jwt:
  secret: ${JWT_SECRET:hr-recruit-jwt-secret-key-change-in-production}
  expiration: 86400000

knife4j:
  enable: true
  setting:
    language: zh_cn
