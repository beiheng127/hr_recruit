@startuml 用例图-人力资源招聘管理系统

left to right direction

actor "HR专员" as HR
actor "部门经理\n/面试官" as Manager
actor "系统管理员" as Admin
actor "候选人" as Candidate
actor "系统（AI）" as AI

rectangle "人力资源招聘管理系统" {
    usecase "UC01\n登录系统" as UC01
    usecase "UC02\n退出登录" as UC02
    usecase "UC03\n新建招聘岗位" as UC03
    usecase "UC04\n发布招聘岗位" as UC04
    usecase "UC05\n关闭招聘岗位" as UC05
    usecase "UC06\n查询招聘岗位" as UC06
    usecase "UC07\n编辑招聘岗位" as UC07
    usecase "UC08\n上传并解析简历" as UC08
    usecase "UC09\n查询简历列表" as UC09
    usecase "UC10\n查看简历详情" as UC10
    usecase "UC11\n候选人投递岗位" as UC11
    usecase "UC12\n安排面试" as UC12
    usecase "UC13\n填写面试评价" as UC13
    usecase "UC14\nAI生成面试评价摘要" as UC14
    usecase "UC15\n发送录用通知（Offer）" as UC15
    usecase "UC16\n确认入职" as UC16
    usecase "UC17\nAI生成岗位JD" as UC17
    usecase "UC18\nAI候选人-岗位匹配评分" as UC18
    usecase "UC19\n查看招聘数据大屏" as UC19
    usecase "UC20\n管理招聘流程管道" as UC20
    usecase "UC21\n管理通知模板" as UC21
    usecase "UC22\n查看操作日志" as UC22
}

' HR专员关联
HR --> UC01
HR --> UC02
HR --> UC03
HR --> UC04
HR --> UC05
HR --> UC06
HR --> UC07
HR --> UC08
HR --> UC09
HR --> UC10
HR --> UC11
HR --> UC12
HR --> UC15
HR --> UC16
HR --> UC17
HR --> UC18
HR --> UC20

' 部门经理/面试官关联
Manager --> UC01
Manager --> UC02
Manager --> UC06
Manager --> UC09
Manager --> UC10
Manager --> UC13
Manager --> UC19

' 系统管理员关联
Admin --> UC01
Admin --> UC02
Admin --> UC06
Admin --> UC21
Admin --> UC22

' 候选人关联
Candidate --> UC01
Candidate --> UC02
Candidate --> UC06
Candidate --> UC11

' AI系统关联（自动触发）
AI --> UC14
AI --> UC17
AI --> UC18

note right of UC14 : 最后一名面试官\n提交评价后自动触发
note right of UC17 : HR专员点击\n"AI生成JD"按钮触发
note right of UC18 : 上传简历后\n或手动触发

@enduml
